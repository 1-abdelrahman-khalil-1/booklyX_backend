{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["app.js", "src/**/*.js"],
  "exclude": [
    "node_modules",
    "src/generated",
    "src/**/__tests__/**"
  ]
}
