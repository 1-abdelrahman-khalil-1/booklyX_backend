generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  client
  staff
  branch_admin
  super_admin
}

enum StaffRole {
  DOCTOR
  BARBER
  SPA_SPECIALIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Platform {
  APP
  WEB
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
}

// ─── Business Application Enums ───────────────────────────────────────────────

enum ApplicationStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum BusinessCategory {
  SPA
  CLINIC
  BARBER
}

enum ApplicationDocumentType {
  TAX_CERTIFICATE
  COMMERCIAL_REGISTER
  NATIONAL_ID
  FACILITY_LICENSE
}

enum ServiceApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

// ─── User & Verification ─────────────────────────────────────────────────────

model User {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique
  password String
  phone    String     @unique
  role     Role
  status   UserStatus @default(ACTIVE)

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  verificationCodes VerificationCode[]
  refreshTokens     RefreshToken[]
  staff             Staff?
  branchAdmin       BranchAdmin?
  client            Client?
}

model Client {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]

  @@index([userId])
}

model VerificationCode {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      VerificationType
  codeHash  String
  expiresAt DateTime
  used      Boolean          @default(false)
  attempts  Int              @default(0)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Business Application ─────────────────────────────────────────────────────

model BranchAdmin {
  id                       Int                           @id @default(autoincrement())
  userId                   Int?                          @unique
  ownerName                String
  email                    String
  phone                    String
  passwordHash             String
  businessName             String
  category                 BusinessCategory
  description              String?
  commercialRegisterNumber String
  taxId                    String
  logoUrl                  String?
  taxCertificateUrl        String?
  commercialRegisterUrl    String?
  nationalIdUrl            String?
  facilityLicenseUrl       String?
  city                     String
  district                 String
  address                  String
  latitude                 Float
  longitude                Float
  status                   ApplicationStatus             @default(PENDING_VERIFICATION)
  emailVerified            Boolean                       @default(false)
  phoneVerified            Boolean                       @default(false)
  rejectionReason          String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  verificationCodes        ApplicationVerificationCode[]
  documents                ApplicationDocument[]
  serviceCategories        ServiceCategory[]
  services                 Service[]
  staffs                   Staff[]
  appointments             Appointment[]
  reviews                  Review[]
  user                     User?                         @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("BranchAdmin")
}

model ApplicationVerificationCode {
  id            Int              @id @default(autoincrement())
  applicationId Int
  type          VerificationType
  codeHash      String
  expiresAt     DateTime
  used          Boolean          @default(false)
  attempts      Int              @default(0)
  createdAt     DateTime         @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type])
}

model ApplicationDocument {
  id            Int                     @id @default(autoincrement())
  applicationId Int
  type          ApplicationDocumentType
  fileUrl       String
  createdAt     DateTime                @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Staff {
  id                   Int                       @id @default(autoincrement())
  userId               Int                       @unique
  branchId             Int
  staffRole            StaffRole
  commissionPercentage Float
  isActive             Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  professionalProfile  StaffProfessionalProfile?
  certificates         StaffCertificate[]
  availabilities       StaffAvailability[]
  appointments         Appointment[]
  user                 User                      @relation(fields: [userId], references: [id])
  branch               BranchAdmin               @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([branchId])
  @@map("Staff")
}

model StaffProfessionalProfile {
  id                Int      @id @default(autoincrement())
  staffId           Int      @unique
  bio               String?
  yearsOfExperience Int?
  licenseNumber     String?
  specialization    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffCertificate {
  id         Int       @id @default(autoincrement())
  staffId    Int
  title      String
  issuer     String
  issueDate  DateTime
  expiryDate DateTime?
  fileUrl    String
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  branchId  Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   BranchAdmin @relation(fields: [branchId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([branchId, name])
  @@index([branchId])
}

model Service {
  id                Int                   @id @default(autoincrement())
  branchId          Int
  serviceCategoryId Int
  name              String
  description       String
  price             Float
  durationMinutes   Int
  imageUrl          String?
  status            ServiceApprovalStatus @default(PENDING_APPROVAL)
  rejectionReason   String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  branch   BranchAdmin     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]

  @@index([branchId])
  @@index([status])
  @@index([branchId, status])
}

model Review {
  id            String   @id @default(uuid())
  clientId      Int
  serviceId     Int
  branchId      Int
  appointmentId String   @unique
  rating        Int // 1 to 5
  comment       String?
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())

  client      Client      @relation(fields: [clientId], references: [id])
  service     Service     @relation(fields: [serviceId], references: [id])
  branch      BranchAdmin @relation(fields: [branchId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([clientId])
}

model Appointment {
  id          String            @id @default(uuid())
  clientId    Int
  staffId     Int
  serviceId   Int
  branchId    Int
  scheduledAt DateTime
  status      AppointmentStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client Client      @relation(fields: [clientId], references: [id])
  staff  Staff       @relation(fields: [staffId], references: [id])
  service Service    @relation(fields: [serviceId], references: [id])
  branch BranchAdmin @relation(fields: [branchId], references: [id])
  review Review?

  @@index([clientId])
  @@index([staffId])
  @@index([serviceId])
  @@index([branchId])
  @@index([status])
}

// ─── STAFF AVAILABILITY ───────────────────────────────

model StaffAvailability {
  id        Int                @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  status    AvailabilityStatus @default(AVAILABLE)

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
}
