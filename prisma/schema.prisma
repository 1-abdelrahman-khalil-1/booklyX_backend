generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  staff
  branch_admin
  super_admin
}

enum StaffRole {
  DOCTOR
  BARBER
  SPA_SPECIALIST
}

enum ServiceStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Platform {
  APP
  WEB
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
}

enum ApplicationStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum BusinessCategory {
  SPA
  CLINIC
  BARBER
}

enum ApplicationDocumentType {
  TAX_CERTIFICATE
  COMMERCIAL_REGISTER
  NATIONAL_ID
  FACILITY_LICENSE
}

enum ServiceApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
}

enum OfferDiscountType {
  PERCENTAGE
  FIXED
}

// ─── User & Verification ─────────────────────────────────────────────────────

model User {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique
  password String
  phone    String     @unique
  role     Role
  status   UserStatus @default(ACTIVE)

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  verificationCodes VerificationCode[]
  refreshTokens     RefreshToken[]
  staff             Staff?
  branchAdmin       BranchAdmin?
  client            Client?
  reviewsGiven      Review[]           @relation("UserReviewsGiven")
}

model Client {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  profileImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]

  @@index([userId])
}

model Staff {
  id                   Int                       @id @default(autoincrement())
  userId               Int                       @unique
  branchId             Int
  profileImageUrl      String?
  age                  Int
  startDate            DateTime
  staffRole            StaffRole
  commissionPercentage Float
  isActive             Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  professionalProfile  StaffProfessionalProfile?
  certificates         StaffCertificate[]
  availabilities       StaffAvailability[]
  appointments         Appointment[]
  services             StaffService[]
  user                 User                      @relation(fields: [userId], references: [id])
  branch               BranchAdmin               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reviews              Review[]
  averageRating        Float                     @default(0)
  reviewCount          Int                       @default(0)

  @@index([userId])
  @@index([branchId])
  @@map("Staff")
}

model BranchAdmin {
  id                       Int                           @id @default(autoincrement())
  userId                   Int?                          @unique
  ownerName                String
  email                    String
  phone                    String
  passwordHash             String
  businessName             String
  category                 BusinessCategory
  description              String?
  commercialRegisterNumber String
  taxId                    String
  logoUrl                  String?
  taxCertificateUrl        String?
  commercialRegisterUrl    String?
  nationalIdUrl            String?
  facilityLicenseUrl       String?
  city                     String
  district                 String
  address                  String
  operatingHours           String?
  latitude                 Float
  longitude                Float
  status                   ApplicationStatus             @default(PENDING_VERIFICATION)
  emailVerified            Boolean                       @default(false)
  phoneVerified            Boolean                       @default(false)
  rejectionReason          String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  verificationCodes        ApplicationVerificationCode[]
  documents                ApplicationDocument[]
  serviceCategories        ServiceCategory[]
  services                 Service[]
  offers                   Offer[]
  staffs                   Staff[]
  appointments             Appointment[]
  reviews                  Review[]
  user                     User?                         @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("BranchAdmin")
}

model VerificationCode {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      VerificationType
  codeHash  String
  expiresAt DateTime
  used      Boolean          @default(false)
  attempts  Int              @default(0)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model RefreshToken {
  id            Int      @id @default(autoincrement())
  userId        Int
  tokenHash     String   @unique
  expiresAt     DateTime
  loginSequence Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApplicationVerificationCode {
  id            Int              @id @default(autoincrement())
  applicationId Int
  type          VerificationType
  codeHash      String
  expiresAt     DateTime
  used          Boolean          @default(false)
  attempts      Int              @default(0)
  createdAt     DateTime         @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type])
}

model ApplicationDocument {
  id            Int                     @id @default(autoincrement())
  applicationId Int
  type          ApplicationDocumentType
  fileUrl       String
  createdAt     DateTime                @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model StaffProfessionalProfile {
  id                Int      @id @default(autoincrement())
  staffId           Int      @unique
  bio               String?
  yearsOfExperience Int?
  licenseNumber     String?
  specialization    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffCertificate {
  id         Int       @id @default(autoincrement())
  staffId    Int
  title      String
  issuer     String
  issueDate  DateTime
  expiryDate DateTime?
  fileUrl    String
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  branchId  Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   BranchAdmin @relation(fields: [branchId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([branchId, name])
  @@index([branchId])
}

model StaffService {
  staffId   Int
  serviceId Int
  createdAt DateTime @default(now())

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
  @@map("StaffService")
}

model Service {
  id                Int                   @id @default(autoincrement())
  branchId          Int
  serviceCategoryId Int?
  name              String
  description       String?
  price             Float
  durationMinutes   Int
  duration          Int?
  imageUrl          String?
  status            ServiceApprovalStatus @default(PENDING_APPROVAL)
  rejectionReason   String?
  approvedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  branch       BranchAdmin      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]
  staffLinks   StaffService[]
  offerLinks   OfferService[]

  @@index([branchId])
  @@index([status])
  @@index([branchId, status])
  @@map("Service")
}

model ServiceExecution {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @unique
  notes         String?
  attachments   Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Offer {
  id            Int               @id @default(autoincrement())
  branchId      Int
  title         String
  description   String?
  discountType  OfferDiscountType
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean           @default(true)
  usageLimit    Int?
  usedCount     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  branch   BranchAdmin    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  services OfferService[]

  @@index([branchId])
  @@index([branchId, isActive])
  @@index([startDate, endDate])
}

model OfferService {
  offerId   Int
  serviceId Int
  createdAt DateTime @default(now())

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([offerId, serviceId])
  @@index([serviceId])
}

model Review {
  id            Int      @id @default(autoincrement())
  clientId      Int?
  reviewerId    Int
  serviceId     Int
  branchId      Int
  staffId       Int
  appointmentId Int?     @unique
  rating        Int
  comment       String?
  isVisible     Boolean  @default(true)
  reviewerRole  Role?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client      Client?      @relation(fields: [clientId], references: [id])
  reviewer    User         @relation("UserReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  service     Service      @relation(fields: [serviceId], references: [id])
  branch      BranchAdmin  @relation(fields: [branchId], references: [id])
  staff       Staff        @relation(fields: [staffId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([clientId])
  @@index([reviewerId])
  @@index([reviewerRole])
  @@index([serviceId])
  @@index([staffId])
  @@index([createdAt])
  @@map("Review")
}

model Appointment {
  id          Int               @id @default(autoincrement())
  clientId    Int
  staffId     Int
  serviceId   Int
  branchId    Int
  scheduledAt DateTime
  status      AppointmentStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client           Client             @relation(fields: [clientId], references: [id])
  staff            Staff              @relation(fields: [staffId], references: [id])
  service          Service            @relation(fields: [serviceId], references: [id])
  branch           BranchAdmin        @relation(fields: [branchId], references: [id])
  review           Review?
  serviceExcutions ServiceExecution[]

  @@index([clientId])
  @@index([staffId])
  @@index([serviceId])
  @@index([branchId])
  @@index([status])

  
}

model StaffAvailability {
  id        Int                @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int
  startTime String
  endTime   String
  status    AvailabilityStatus @default(AVAILABLE)

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
}

model SystemCounter {
  key   String @id
  value Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
