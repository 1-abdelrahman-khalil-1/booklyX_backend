generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  client
  staff
  branch_admin
  super_admin
}

enum StaffRole {
  DOCTOR
  BARBER
  SPA_SPECIALIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Platform {
  APP
  WEB
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
}

// ─── Business Application Enums ───────────────────────────────────────────────

enum ApplicationStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum BusinessCategory {
  SPA
  CLINIC
  BARBER
}

enum ApplicationDocumentType {
  TAX_CERTIFICATE
  COMMERCIAL_REGISTER
  NATIONAL_ID
  FACILITY_LICENSE
}

// ─── User & Verification ─────────────────────────────────────────────────────

model User {
  id       Int        @id @default(autoincrement())
  name     String
  email    String     @unique
  password String
  phone    String     @unique
  role     Role
  status   UserStatus @default(ACTIVE)

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  verificationCodes VerificationCode[]
  refreshTokens     RefreshToken[]
  staff             Staff?
  branchAdmin       BranchAdmin?
}

model VerificationCode {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      VerificationType
  codeHash  String
  expiresAt DateTime
  used      Boolean          @default(false)
  attempts  Int              @default(0)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Business Application ─────────────────────────────────────────────────────

model BranchAdmin {
  id                       Int               @id @default(autoincrement())
  userId                   Int?              @unique
  ownerName                String
  email                    String 
  phone                    String 
  passwordHash             String
  businessName             String
  category                 BusinessCategory
  description              String?
  commercialRegisterNumber String
  taxId                    String
  logoUrl                  String?
  taxCertificateUrl        String?
  commercialRegisterUrl    String?
  nationalIdUrl            String?
  facilityLicenseUrl       String?
  city                     String
  district                 String
  address                  String
  latitude                 Float
  longitude                Float
  status                   ApplicationStatus @default(PENDING_VERIFICATION)
  emailVerified            Boolean           @default(false)
  phoneVerified            Boolean           @default(false)
  rejectionReason          String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  verificationCodes ApplicationVerificationCode[]
  documents         ApplicationDocument[]
  staffs            Staff[]
  user              User?                         @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("BranchAdmin")
}

model ApplicationVerificationCode {
  id            Int              @id @default(autoincrement())
  applicationId Int
  type          VerificationType
  codeHash      String
  expiresAt     DateTime
  used          Boolean          @default(false)
  attempts      Int              @default(0)
  createdAt     DateTime         @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, type])
}

model ApplicationDocument {
  id            Int                     @id @default(autoincrement())
  applicationId Int
  type          ApplicationDocumentType
  fileUrl       String
  createdAt     DateTime                @default(now())

  application BranchAdmin @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Staff {
  id                   Int       @id @default(autoincrement())
  userId               Int       @unique
  branchId             Int
  staffRole            StaffRole
  commissionPercentage Float
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  professionalProfile StaffProfessionalProfile?
  certificates        StaffCertificate[]
  user   User        @relation(fields: [userId], references: [id])
  branch BranchAdmin @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([branchId])
  @@map("Staff")
}

model StaffProfessionalProfile {
  id                Int      @id @default(autoincrement())
  staffId           Int      @unique
  bio               String?
  yearsOfExperience Int?
  licenseNumber     String?
  specialization    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffCertificate {
  id         Int       @id @default(autoincrement())
  staffId    Int
  title      String
  issuer     String
  issueDate  DateTime
  expiryDate DateTime?
  fileUrl    String
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}
