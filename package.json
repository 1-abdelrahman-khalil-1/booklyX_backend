{
  "name": "booklyx_backend",
  "version": "1.0.0",
  "description": "Backend API for BooklyX (graduation project), built with **Node.js**, **Express 5**, **TypeScript**, **Prisma 6**, **Zod**, and **MySQL**.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "dev": "nodemon  --watch app.js",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "openapi:validate": "npm exec swagger-cli validate openapi.yaml",
    "api:login": "node scripts/api-session.mjs login",
    "api:refresh": "node scripts/api-session.mjs refresh",
    "api:session": "node scripts/api-session.mjs show",
    "api:logout": "node scripts/api-session.mjs clear",
    "api:export:apidog": "node scripts/api-session.mjs export-apidog",
    "api:export:env": "node scripts/api-session.mjs export-env",
    "apidog:sync": "node scripts/push-apidog-openapi.mjs",
    "translate:deepl": "node scripts/translate-deepl.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18 <19",
    "npm": ">=9 <11"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "deepl-node": "^1.24.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "prisma": "^6.16.3",
    "zod": "^4.3.6"
  },
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1-abdelrahman-khalil-1/booklyX_backend.git"
  },
  "bugs": {
    "url": "https://github.com/1-abdelrahman-khalil-1/booklyX_backend/issues"
  },
  "homepage": "https://github.com/1-abdelrahman-khalil-1/booklyX_backend#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
