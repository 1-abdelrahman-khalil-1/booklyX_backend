# ============================================
# DATABASE & SECURITY
# ============================================
DATABASE_URL=""
JWT_SECRET=""
NODE_ENV="production"
VERIFICATION_CODE_EXPIRES_MINUTES="10"

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_HOST="smtp.ethereal.email"
EMAIL_PORT="587"
EMAIL_USER="your-ethereal-username"
EMAIL_PASS="your-ethereal-password"
EMAIL_FROM="BooklyX <noreply@booklyx.com>"
APP_URL="http://localhost:3000"

# ============================================
# POSTMAN API INTEGRATION
# ============================================
# Get API Key from: https://www.postman.com/settings/me/api-keys
POSTMAN_API_KEY=""

# Your Postman Workspace ID (found in workspace URL)
POSTMAN_WORKSPACE_ID=""

# Collection UID - Auto-generated after first sync (see terminal output)
# If left empty, a new collection will be created
POSTMAN_COLLECTION_UID=""

# Environment UID - Auto-generated after first sync (see terminal output)
# If left empty, a new environment will be created
POSTMAN_ENVIRONMENT_UID=""

