{
  "info": {
    "name": "BooklyX Backend",
    "description": "BooklyX backend API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "description": "Enum parameters:\n- Header `platform`: APP | WEB\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdo Khalil\",\n  \"email\": \"khalil@booklyx.com\",\n  \"password\": \"12345678\",\n  \"phone\": \"0123456789\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "description": "Enum parameters:\n- Header `platform`: APP | WEB\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\",\n  \"password\": \"12345678\",\n  \"role\": \"client\" // \"client\", \"branch_admin\", \"super_admin\", \"staff\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  const role = json.data.user ? json.data.user.role : json.data.role;",
                  "  const token = json.data.token;",
                  "  const refreshToken = json.data.refreshToken;",
                  "  ",
                  "  if (token) {",
                  "    if (role === 'client') pm.environment.set('clientToken', token);",
                  "    if (role === 'branch_admin') pm.environment.set('branchAdminToken', token);",
                  "    if (role === 'staff') pm.environment.set('staffToken', token);",
                  "    if (role === 'super_admin') pm.environment.set('adminToken', token);",
                  "  }",
                  "  ",
                  "  if (refreshToken) {",
                  "    if (role === 'client') pm.environment.set('refreshClientToken', refreshToken);",
                  "    if (role === 'branch_admin') pm.environment.set('refreshBranchAdminToken', refreshToken);",
                  "    if (role === 'staff') pm.environment.set('refreshStaffToken', refreshToken);",
                  "    if (role === 'super_admin') pm.environment.set('refreshAdminToken', refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "description": "Enum parameters:\n- Header `platform`: APP | WEB (this request uses WEB)\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "en" },
              { "key": "platform", "value": "WEB" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@booklyx.com\",\n  \"password\": \"12345678\",\n  \"role\": \"super_admin\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  const token = json.data.token;",
                  "  const refreshToken = json.data.refreshToken;",
                  "  if (token) {",
                  "    pm.environment.set('adminToken', token);",
                  "  }",
                  "  if (refreshToken) {",
                  "    pm.environment.set('refreshAdminToken', refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-email"
          }
        },
        {
          "name": "Verify Phone",
          "request": {
            "method": "POST",
            "description": "Enum parameters:\n- Header `platform`: APP | WEB\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-phone"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('clientToken', json.data.token);",
                  "}",
                  "if (json && json.data && json.data.refreshToken) {",
                  "  pm.environment.set('refreshClientToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Resend Code",
          "request": {
            "method": "POST",
            "description": "Enum parameters:\n- Body `type`: EMAIL | PHONE | PASSWORD_RESET\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\",\n  \"phone\": \"0123456789\",\n  \"type\": \"EMAIL\" // \"PHONE\", \"PASSWORD_RESET\"\n}"
            },
            "url": "{{baseUrl}}/auth/resend-code"
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/request-password-reset"
          }
        },
        {
          "name": "Verify Password Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"khalil@booklyx.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-password-reset"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.resetToken) {",
                  "  pm.environment.set('resetToken', json.data.resetToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshClientToken}}\" // or refreshBranchAdminToken, refreshStaffToken, refreshAdminToken\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data) {",
                  "  const role = json.data.role;",
                  "  const token = json.data.token;",
                  "  const refreshToken = json.data.refreshToken;",
                  "  ",
                  "  if (token) {",
                  "    pm.environment.set('token', token);",
                  "    if (role === 'client') pm.environment.set('clientToken', token);",
                  "    if (role === 'branch_admin') pm.environment.set('branchAdminToken', token);",
                  "    if (role === 'staff') pm.environment.set('staffToken', token);",
                  "    if (role === 'super_admin') pm.environment.set('adminToken', token);",
                  "  }",
                  "  ",
                  "  if (refreshToken) {",
                  "    if (role === 'client') pm.environment.set('refreshClientToken', refreshToken);",
                  "    if (role === 'branch_admin') pm.environment.set('refreshBranchAdminToken', refreshToken);",
                  "    if (role === 'staff') pm.environment.set('refreshStaffToken', refreshToken);",
                  "    if (role === 'super_admin') pm.environment.set('refreshAdminToken', refreshToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
