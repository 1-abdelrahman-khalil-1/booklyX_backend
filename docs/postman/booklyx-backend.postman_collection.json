    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "description": "Enum parameters:\n- Query `status`: PENDING_VERIFICATION | PENDING_APPROVAL | APPROVED | REJECTED\n- Header `platform`: APP | WEB (this request uses WEB)\n- Header `Accept-Language`: en | ar",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/applications?status=PENDING_APPROVAL",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "applications"],
              "query": [{ "key": "status", "value": "PENDING_APPROVAL" }]
            }
          }
        },
        {
          "name": "Get Application Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/applications/1"
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/applications/1/approve"
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Incomplete data\"\n}"
            },
            "url": "{{baseUrl}}/admin/applications/1/reject"
          }
        }
      ]
    }
  ]
}
