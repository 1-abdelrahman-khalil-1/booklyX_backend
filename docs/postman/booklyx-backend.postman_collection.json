{
  "info": {
    "name": "BooklyX Backend",
    "description": "BooklyX backend API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdo Khalil\",\n  \"email\": \"client@example.com\",\n  \"password\": \"12345678\",\n  \"phone\": \"0123456789\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "en" },
              { "key": "platform", "value": "WEB" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@booklyx.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('token', json.data.token);",
                  "  console.log('Admin token saved to environment variable');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-email"
          }
        },
        {
          "name": "Verify Phone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-phone"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Resend Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"phone\": \"0123456789\",\n  \"type\": \"EMAIL\" // \"PHONE\", \"PASSWORD_RESET\"\n}"
            },
            "url": "{{baseUrl}}/auth/resend-code"
          }
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/request-password-reset"
          }
        },
        {
          "name": "Verify Password Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@example.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-password-reset"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.resetToken) {",
                  "  pm.environment.set('resetToken', json.data.resetToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Branch Admin",
      "item": [
        {
          "name": "Apply",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"Abdo Khalil\",\n  \"email\": \"branch@example.com\",\n  \"phone\": \"0101234567\",\n  \"password\": \"12345678\",\n  \"businessName\": \"Khalil Spa\",\n  \"category\": \"SPA\" // \"CLINIC\", \"BARBER\",\n  \"description\": \"Premium spa services\",\n  \"city\": \"Cairo\",\n  \"district\": \"Tahrir Square\",\n  \"address\": \"Tahrir Square\",\n  \"taxId\": \"123456789\",\n  \"commercialRegisterNumber\": \"123456789\",\n  \"latitude\": 30.0444,\n  \"longitude\": 31.2357\n}"
            },
            "url": "{{baseUrl}}/branch-admin/apply"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"branch@example.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/branch-admin/verify-email"
          }
        },
        {
          "name": "Verify Phone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"branch@example.com\",\n  \"code\": \"333333\"\n}"
            },
            "url": "{{baseUrl}}/branch-admin/verify-phone"
          }
        },
        {
          "name": "Resend Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"branch@example.com\",\n  \"type\": \"EMAIL\" // \"PHONE\"\n}"
            },
            "url": "{{baseUrl}}/branch-admin/resend-code"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/applications?status=PENDING_APPROVAL",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "applications"],
              "query": [{ "key": "status", "value": "PENDING_APPROVAL" }]
            }
          }
        },
        {
          "name": "Get Application Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/admin/applications/1"
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/admin/applications/1/approve"
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "WEB" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Incomplete data\"\n}"
            },
            "url": "{{baseUrl}}/admin/applications/1/reject"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User (Staff/Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{lang}}" },
              { "key": "platform", "value": "{{platform}}" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"staff@example.com\",\n  \"password\": \"12345678\",\n  \"phone\": \"0123456780\",\n  \"role\": \"staff\" // \"client\", \"branch_admin\", \"super_admin\"\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        }
      ]
    }
  ]
}
